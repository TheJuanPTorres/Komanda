# Variables de entorno del servidor POS (Fase Nube — VPS público tras Caddy).
# Copia este archivo a .env y complétalo. NUNCA commitees el .env real.
#
# En PRODUCCIÓN (NODE_ENV=production), COOKIE_SECRET y ORIGEN_PERMITIDO son
# OBLIGATORIAS: si faltan, el servidor no arranca (falla en frío con mensaje).

# development | production | test
NODE_ENV=production

# Puerto interno del proceso Node (Caddy hace reverse-proxy a este puerto).
PORT=3000
HOST=127.0.0.1

# Secreto para firmar la cookie de sesión (JWT). MÍNIMO 32 caracteres.
# Genera uno con:  openssl rand -base64 48
COOKIE_SECRET=cambia-esto-por-un-secreto-largo-de-al-menos-32-chars

# Origen público permitido (CORS + Socket.IO). Debe coincidir con el dominio
# real servido por Caddy, con https://
ORIGEN_PERMITIDO=https://pos.midominio.com

# Carpeta de datos persistentes (base SQLite + imágenes de producto).
# En el VPS suele ser una ruta absoluta bajo /opt o /var.
RUTA_DATOS=/opt/pos/server/data

# Zona horaria del NEGOCIO (fronteras de "día operativo"). No la del servidor.
TZ_NEGOCIO=America/Bogota
